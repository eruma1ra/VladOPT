NODE_ENV=production
PORT=5000
APP_PUBLIC_PORT=5000
SITE_URL=https://vladopt.ru
VITE_SITE_URL=https://vladopt.ru
CANONICAL_HOST=vladopt.ru
FORCE_HTTPS=true

# PostgreSQL (for docker service `db`)
POSTGRES_DB=vladopt_prod
POSTGRES_USER=vladopt
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Auth
AUTH_MODE=google
SESSION_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
ADMIN_EMAILS=elimirka91@gmail.com,tdvlad20@gmail.com

# Google OAuth
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=https://vladopt.ru/api/callback

# Request notifications
REQUEST_NOTIFY_EMAIL=sale@vladopt.ru

# SMTP
# Option A:
# SMTP_URL=smtps://USER:PASS@smtp.example.com:465
# Option B:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=YOUR_SMTP_LOGIN
SMTP_PASS=YOUR_SMTP_PASSWORD
SMTP_FROM=YOUR_SMTP_LOGIN

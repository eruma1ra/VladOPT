PORT=5000

# Local PostgreSQL (replace DB user if needed)
DATABASE_URL=postgresql://YOUR_DB_USER@localhost:5432/vladopt_local

# Development defaults
AUTH_MODE=local

# Google OAuth (required when AUTH_MODE=google)
# SESSION_SECRET=change-this-secret
# ADMIN_EMAILS=admin@yourcompany.com
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:5000/api/callback

# Request notifications email (optional in local dev)
# REQUEST_NOTIFY_EMAIL=sale@vladopt.ru
# SMTP_URL=smtps://user:pass@smtp.example.com:465
# or use explicit SMTP fields:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=no-reply@vladopt.ru

# Replit OIDC (optional legacy mode)
# REPL_ID=
# ISSUER_URL=https://replit.com/oidc
